<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Logger.Wpf.Controls;assembly=Logger.Wpf"
        mc:Ignorable="d"
        Title="Logger WPF Showcase"
        Height="720"
        Width="1080"
        MinHeight="560"
        MinWidth="860"
        Background="#FFFFFFFF">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFFFF" Offset="0" />
            <GradientStop Color="#FFFFFFFF" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF0F172A" Offset="0" />
            <GradientStop Color="#FF1E3A8A" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF38BDF8" Offset="0" />
            <GradientStop Color="#FF2563EB" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="#332563EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FF0F172A" />
            <Setter Property="Background" Value="#F8FBFF" />
            <Setter Property="BorderBrush" Value="#FFD8E4F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FF94A3B8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FFE8EEF7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoChipStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="420"
                     Height="420"
                     Fill="Transparent"
                     Canvas.Left="-110"
                     Canvas.Top="-100" />
            <Ellipse Width="360"
                     Height="360"
                     Fill="Transparent"
                     Canvas.Right="-90"
                     Canvas.Top="40" />
        </Canvas>

        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource HeroBrush}"
                    CornerRadius="16"
                    Padding="14,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16"
                                      ShadowDepth="0"
                                      Opacity="0.12"
                                      Color="#FF0F172A" />
                </Border.Effect>

                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontFamily="Microsoft YaHei UI"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="Logger WPF 控制台" />
                        <TextBlock Margin="0,8,0,0"
                                   FontFamily="Microsoft YaHei UI"
                                   FontSize="11"
                                   Foreground="#D8E7FF"
                                   Text="压力测试和日志控件放在同一屏，方便直接观察日志刷新的效果。"
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,10,0,0">
                            <Border Style="{StaticResource InfoChipStyle}">
                                <TextBlock FontFamily="Microsoft YaHei UI"
                                           FontSize="9"
                                           Foreground="White"
                                           Text="30000 条压力写入" />
                            </Border>
                            <Border Style="{StaticResource InfoChipStyle}">
                                <TextBlock FontFamily="Microsoft YaHei UI"
                                           FontSize="9"
                                           Foreground="White"
                                           Text="日志实时滚动" />
                            </Border>
                            <Border Style="{StaticResource InfoChipStyle}">
                                <TextBlock FontFamily="Microsoft YaHei UI"
                                           FontSize="9"
                                           Foreground="White"
                                           Text="ILoggerOutput 绑定" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFE5E7EB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="14">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="0"
                                          Opacity="0.08"
                                          Color="#FF0F172A" />
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock FontFamily="Microsoft YaHei UI"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="#FF0F172A"
                                   Text="压力测试" />
                        <TextBlock Margin="0,6,0,0"
                                   FontFamily="Microsoft YaHei UI"
                                   FontSize="11"
                                   Foreground="#FF64748B"
                                   Text="点击后会持续写入日志，你可以在右侧直接看到效果。"
                                   TextWrapping="Wrap" />

                        <Button x:Name="BtnStressTest"
                                Margin="0,16,0,0"
                                Content="运行压力测试"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Click="BtnStressTest_Click" />

                        <Border Margin="0,12,0,0"
                                Padding="10,8"
                                Background="#FFF8FBFF"
                                BorderBrush="#FFD8E4F0"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock FontFamily="Microsoft YaHei UI"
                                           FontSize="9"
                                           Foreground="#FF64748B"
                                           Text="状态" />
                                <TextBlock x:Name="TxtStatus"
                                           Margin="0,4,0,0"
                                           FontFamily="Microsoft YaHei UI"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#FF0F172A"
                                           Text="就绪"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <controls:LogTextPanelControl Grid.Column="2"
                                              x:Name="LogViewer"
                                              Header="应用日志"
                                              MaxLogEntries="5000" />
            </Grid>
        </Grid>
    </Grid>
</Window>
